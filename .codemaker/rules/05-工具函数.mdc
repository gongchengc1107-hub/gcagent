## 常用工具函数速查（src/utils/util.ts）

```typescript
import util from '@/utils/util';

// ── 文件下载 ──────────────────────────────────────────
util.downloadFile({ url, filename?, needFetch? })  // 单文件下载
util.downloadFiles(files: { url? }[])              // 批量下载

// ── 复制到剪贴板 ──────────────────────────────────────
util.copy(text, msg?)   // msg=false 则不显示 toast

// ── 数字格式化 ────────────────────────────────────────
util.addCommas(n)        // 数字加千分位逗号：1234567 → '1,234,567'
util.bytesToSize(bytes)  // 字节转可读大小：1024 → '1 KB'
util.shiftToKW(n)        // 数字转 k/w 格式：10000 → '1w'
util.numToZN(num)        // 数字转中文

// ── URL 处理 ──────────────────────────────────────────
util.parseUrl('/api/:id/:type', [1, 'work'])  // → '/api/1/work'
util.isUrl(text)
util.getHostname(url)
util.openLink(url, target?)  // 自动补全 http://

// ── 表单 / 过滤 ───────────────────────────────────────
util.checkForm(formFields)                              // 清除 null/undefined/空数组，保留 0/false
util.searchTextHandle(originText, setter, pageSetter?)  // 搜索防抖（自动重置第1页）
util.filterPageHandle(setter, pageSetter?)              // 过滤器变更时重置页码

// ── 树操作 ────────────────────────────────────────────
util.traverseTree(nodes, callback)
util.traverseTreeRevert(nodes, callback)
util.getFieldByTraverseTree(node, fieldPath)
util.findPathByTraverseTree(nodes, checker)
util.mapTreeNodeWithKey(nodes, getKey, getNode?)  // → Map<key, TreeNode>
util.deleteInTree(nodes, checkDelete)
util.insertIntoTree(nodes, insertNode, checkInsert)

// ── 权限辅助 ──────────────────────────────────────────
util.checkAccess(accessKey, access, userInfo, route?, extra?)
util.checkRoles(need, has)

// ── 其他 ──────────────────────────────────────────────
util.sleep(ms)
util.stopEvent(e)
util.getPopContainer(trigger)   // 获取最近滚动容器（用于 Select/Dropdown 的 getPopupContainer）
util.middle(max, min, num)      // 限制数字在 [min, max] 范围内
```

